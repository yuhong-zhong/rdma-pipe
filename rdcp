#!/bin/bash

args=
recursive=
verbose=

while getopts vr flag
do
    case "${flag}" in
        v) args="$args -v"; verbose="-v";;
        r) args="$args -r"; recursive="1";;
    esac
done

source=${@:$OPTIND:1}
target=${@:$OPTIND+1:1}

ssh=$(which ssh)
ssh_flags="-t -t -o BatchMode=yes -o ConnectTimeout=5 -o ServerAliveInterval=5 -o ServerAliveCountMax=1"

# Split the host:filename into host and filename
# If there is no : set host to ""

if [ "$source" = "" ]; then
    echo "Usage: $0 [-v] [-r] source target"
    exit
fi
# Check if source contains a colon
if [[ $source == *":"* ]]; then
    # Split source into host and filename
    source_host=${source%%:*}
    source_filename=${source#*:}
else
    # No colon, so set host to ""
    source_host=""
    source_filename=$source
    if [ $source_filename = "-" ]
    then
        source_filename="/dev/stdin"
    fi
fi

if [ "$target" = "" ]; then
    echo "Usage: $0 [-v] [-r] source target"
    exit
fi
# Check if target contains a colon
if [[ $target == *":"* ]]; then
    # Split target into host and filename
    target_host=${target%%:*}
    target_filename=${target#*:}
else
    # No colon, so set host to ""
    target_host=""
    target_filename=$target
    if [ $target_filename = "-" ]
    then
        target_filename="/dev/stdout"
    fi
fi

# Check if source is a directory and -r flag is not set
if [ "$recursive" = "" ]; then
    # Check if source is a local directory
    if [ "$source_host" = "" ]; then
        if [ -d "$source_filename" ]; then
            echo "rdcp: $source_filename: Is a directory (use -r to copy directories)" >&2
            exit 1
        elif [ ! -e "$source_filename" ] && [ "$source_filename" != "/dev/stdin" ]; then
            echo "rdcp: $source_filename: No such file or directory" >&2
            exit 1
        fi
    fi
    # For remote sources, we'll check via ssh
    if [ "$source_host" != "" ]; then
        ssh_check_output=$($ssh $ssh_flags $source_host "if [ -d \"$source_filename\" ]; then echo DIR; elif [ -e \"$source_filename\" ]; then echo FILE; else echo NOTFOUND; fi" 2>&1)
        ssh_check_status=$?
        if [ $ssh_check_status -ne 0 ]; then
            echo "rdcp: Failed to connect to $source_host via SSH" >&2
            echo "rdcp: Run 'rdcheck $source_host' to diagnose connectivity issues." >&2
            exit 1
        fi
        if [ "$ssh_check_output" = "DIR" ]; then
            echo "rdcp: $source_filename: Is a directory (use -r to copy directories)" >&2
            exit 1
        elif [ "$ssh_check_output" = "NOTFOUND" ]; then
            echo "rdcp: $source_filename: No such file or directory" >&2
            exit 1
        fi
    fi
fi

# If the host is the same as the target, then we can just copy the file
# locally.  Otherwise, we need to copy it remotely.

if [ "$source_host" = "$target_host" ]; then
    if [ "$source_host" = "" ]; then
        if [ "$recursive" = "1" ]; then
            cp -a "$source_filename" "$target_filename"
        else
            cp "$source_filename" "$target_filename"
        fi
    else
        if [ "$recursive" = "1" ]; then
            $ssh $ssh_flags $source_host cp -a "$source_filename" "$target_filename"
        else
            $ssh $ssh_flags $source_host cp "$source_filename" "$target_filename"
        fi
    fi
    exit
fi

# Remote copy using the rdma protocol.
# We use rdsend on the source host to send the file, and rdrecv to receive it.

# Pre-flight check: verify rdsend/rdrecv are available on each host.

if [ "$target_host" != "" ]; then
    target_check=$($ssh $ssh_flags $target_host "command -v rdrecv 2>/dev/null && echo RDRECV_OK" 2>&1)
    target_ssh_status=$?
    if [ $target_ssh_status -ne 0 ]; then
        echo "rdcp: Failed to connect to $target_host via SSH" >&2
        echo "rdcp: Run 'rdcheck $target_host' to diagnose connectivity issues." >&2
        exit 1
    fi
    if ! echo "$target_check" | grep -q "RDRECV_OK"; then
        echo "rdcp: rdrecv not found on $target_host" >&2
        echo "rdcp: Install rdma-pipe on $target_host with: sudo make install" >&2
        exit 1
    fi
fi

if [ "$source_host" != "" ]; then
    source_check=$($ssh $ssh_flags $source_host "command -v rdsend 2>/dev/null && echo RDSEND_OK" 2>&1)
    source_ssh_status=$?
    if [ $source_ssh_status -ne 0 ]; then
        echo "rdcp: Failed to connect to $source_host via SSH" >&2
        echo "rdcp: Run 'rdcheck $source_host' to diagnose connectivity issues." >&2
        exit 1
    fi
    if ! echo "$source_check" | grep -q "RDSEND_OK"; then
        echo "rdcp: rdsend not found on $source_host" >&2
        echo "rdcp: Install rdma-pipe on $source_host with: sudo make install" >&2
        exit 1
    fi
fi

if [ "$target_host" = "" ] && ! command -v rdrecv >/dev/null 2>&1; then
    echo "rdcp: rdrecv not found locally" >&2
    echo "rdcp: Install rdma-pipe with: sudo make install" >&2
    exit 1
fi

if [ "$source_host" = "" ] && ! command -v rdsend >/dev/null 2>&1; then
    echo "rdcp: rdsend not found locally" >&2
    echo "rdcp: Install rdma-pipe with: sudo make install" >&2
    exit 1
fi

# Pick a random port number to use for the rdma connection.
# We use the same port number for both rdsend and rdrecv.

rdma_target_host=${target_host#*@}

port=$(( 10000 + ( RANDOM % 10000 ) ))

# Pick a random password to use for the rdma connection.

password=$(head -c 12 /dev/urandom | od -An -t x | tr -d ' ')

# If any of the programs fail, kill them all to avoid leaving zombies.

cleanup() {
    kill -HUP $recv_pid $send_pid 2>/dev/null
}
trap cleanup EXIT

# Wait for both background processes and report RDMA errors helpfully.
rdma_wait() {
    local diag_host="${1:-}"
    wait
    local result=$?
    if [ $result -ne 0 ]; then
        echo "rdcp: RDMA transfer failed (exit code $result)" >&2
        if [ -n "$diag_host" ]; then
            echo "rdcp: Run 'rdcheck $diag_host' to diagnose RDMA connectivity issues." >&2
        else
            echo "rdcp: Run 'rdcheck' to diagnose RDMA connectivity issues." >&2
        fi
        exit $result
    fi
}

if [ "$recursive" = "1" ]; then
    # This should work like cp -a source target 
    # If target doesn't exist, create it. If it does, copy source into target/source.
    # (cd src && tar c .) | ((cd dst && mkdir src && tar xC src) || (mkdir dst && tar xC dst))
    source_basename=$(basename "$source_filename")
    if [ "$source_host" = "" ]; then
        $ssh $ssh_flags $target_host rdrecv $verbose $port $password \| \(\(cd "$target_filename" 2\>/dev/null \&\& mkdir "$source_basename" \&\& tar xC "$source_basename"\) \|\| \(mkdir "$target_filename" \&\& tar xC "$target_filename"\)\) &
        recv_pid=$!
        # send from source filename
        (cd "$source_filename" && tar c .) | rdsend $verbose $rdma_target_host $port $password &
        send_pid=$!
        rdma_wait "$target_host"
    elif [ "$target_host" = "" ]; then
        rdrecv $verbose $port $password | ((cd "$target_filename" 2>/dev/null && mkdir "$source_basename" && tar xC "$source_basename") || (mkdir "$target_filename" && tar xC "$target_filename")) &
        recv_pid=$!
        $ssh $ssh_flags $source_host \(cd "$source_filename" \&\& tar c .\) \| rdsend $verbose \$\{SSH_CLIENT%% \*\} $port $password &
        send_pid=$!
        rdma_wait "$source_host"
    else
        $ssh $ssh_flags $target_host rdrecv $verbose $port $password \| \(\(cd "$target_filename" 2\>/dev/null \&\& mkdir "$source_basename" \&\& tar xC "$source_basename"\) \|\| \(mkdir "$target_filename" \&\& tar xC "$target_filename"\)\) &
        recv_pid=$!
        $ssh $ssh_flags $source_host \(cd "$source_filename" \&\& tar c .\) \| rdsend $verbose $rdma_target_host $port $password &
        send_pid=$!
        rdma_wait "$target_host"
    fi
else
    if [ "$source_host" = "" ]; then
        # pipe to target filename
        $ssh $ssh_flags $target_host rdrecv $verbose $port $password "$target_filename" &
        recv_pid=$!
        # send from source filename
        rdsend $verbose $rdma_target_host $port $password < "$source_filename" &
        send_pid=$!
        rdma_wait "$target_host"
    elif [ "$target_host" = "" ]; then
        rdrecv $verbose $port $password "$target_filename" &
        recv_pid=$!
        $ssh $ssh_flags $source_host rdsend $verbose \$\{SSH_CLIENT%% \*\} $port $password \< "$source_filename"
        send_pid=$!
        rdma_wait "$source_host"
    else
        $ssh $ssh_flags $target_host rdrecv $verbose $port $password "$target_filename" &
        recv_pid=$!
        $ssh $ssh_flags $source_host rdsend $verbose $rdma_target_host $port $password \< "$source_filename" &
        send_pid=$!
        rdma_wait "$target_host"
    fi
fi
