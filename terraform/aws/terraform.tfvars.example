# Example Terraform variables file
# Copy this to terraform.tfvars and customize

# AWS Region (choose based on instance availability)
# Options: us-east-1, us-west-2, eu-west-1
region = "us-east-1"

# Instance type - must support EFA
# Budget: c5n.18xlarge ($3.89/hr)
# GPU+EFA: p4d.24xlarge ($32.77/hr)
instance_type = "c5n.18xlarge"

# Number of instances for benchmark (minimum 2)
instance_count = 2

# SSH key name (must exist in AWS)
# Create with: aws ec2 create-key-pair --key-name rdma-benchmark
key_name = "your-ssh-key-name"

# Your IP address for SSH access
# Get with: curl ifconfig.me
my_ip = "0.0.0.0/0"  # Replace with your.ip.address/32 for security
